public class ControlEnemigos {
    private Enemigo[] enemigos;
    private Jugador jugador;
    private Tablero tablero;
    private int totalEnemigos;

    public ControlEnemigos(Enemigo[] enemigos, Jugador jugador, Tablero tablero, int totalEnemigos) {
        this.enemigos = enemigos;
        this.jugador = jugador;
        this.tablero = tablero;
        this.totalEnemigos = totalEnemigos;
    }

    public void generarMovimientos() {
        if (jugador.isPoderActivo() && "Congelar enemigos".equals(jugador.getTipoPoderActivo())) {
            System.out.println("¡Los enemigos están congelados! No pueden moverse este turno.");
            return;
        }
        moverEnemigos();
    }

    public void moverEnemigos() {
        for (int i = 0; i < totalEnemigos; i++) {
            if (enemigos[i] != null && enemigos[i].isActivo()) {
                enemigos[i].mover(tablero, jugador);
            }
        }
    }

    public void verificarColisiones() {
        for (int i = 0; i < totalEnemigos; i++) {
            if (enemigos[i] != null && enemigos[i].isActivo()) {
                if (enemigos[i].verificarColision(jugador)) {
                    enemigos[i].atacar(jugador);
                }
            }
        }
    }

    public void eliminarEnemigosInactivos() {
        for (int i = 0; i < totalEnemigos; i++) {
            if (enemigos[i] != null && !enemigos[i].isActivo()) {
                System.out.println("El enemigo tipo '" + enemigos[i].getTipo() + "' ha sido eliminado del juego.");
                enemigos[i] = null;
            }
        }
    }

    public Enemigo[] getEnemigos() { return enemigos; }
    public void setEnemigos(Enemigo[] enemigos) { this.enemigos = enemigos; }
}
