public class Poder {
    private String tipo;
    private int duracion;
    private int fila;
    private int columna;

    public Poder(String tipo, int duracion, int fila, int columna) {
        this.tipo = tipo;
        this.duracion = duracion;
        this.fila = fila;
        this.columna = columna;
    }

    public void activar(Jugador j) {
        switch (tipo) {
            case "Invulnerabilidad":
                System.out.println(j.getNombre() + " es invulnerable durante " + duracion + " turnos.");
                break;
            case "Congelar enemigos":
                System.out.println("Los enemigos quedaron congelados durante " + duracion + " turnos.");
                break;
            case "Recuperación de salud":
                j.setSalud(j.getSalud() + 1);
                System.out.println(j.getNombre() + " recuperó salud → Salud actual: " + j.getSalud());
                break;
            default:
                System.out.println("Poder desconocido: " + tipo);
        }
    }

    public String descripcion() {
        switch (tipo) {
            case "Invulnerabilidad":
                return "Invulnerabilidad: el jugador no recibe daño durante " + duracion + " turnos.";
            case "Congelar enemigos":
                return "Congelar enemigos: los enemigos no se mueven durante " + duracion + " turnos.";
            case "Recuperación de salud":
                return "Recuperación de salud: restaura 1 punto de salud al jugador.";
            default:
                return "Poder no definido.";
        }
    }

    public String getTipo() { return tipo; }
    public void setTipo(String tipo) { this.tipo = tipo; }
    public int getDuracion() { return duracion; }
    public void setDuracion(int duracion) { this.duracion = duracion; }
    public int getFila() { return fila; }
    public int getColumna() { return columna; }
}
