public class EnemigoAleatorio {
    private String tipo;
    private int fila;
    private int columna;
    private int daño;
    private boolean activo;

    public EnemigoAleatorio(int fila, int columna) {
        this.tipo = "aleatorio";
        this.fila = fila;
        this.columna = columna;
        this.daño = 3;
        this.activo = true;
    }

    // Mueve el enemigo en una dirección aleatoria, validando con el tablero
    public void mover(Tablero tablero) {
        if (!activo) return;

        int direccion = (int)(Math.random() * 4);
        int nuevaFila = this.fila;
        int nuevaColumna = this.columna;

        switch (direccion) {
            case 0:
                nuevaFila--;
                break; // arriba
            case 1:
                nuevaFila++;
                break; // abajo
            case 2:
                nuevaColumna--;
                break; // izquierda
            case 3:
                nuevaColumna++;
                break; // derecha
        }

        // Verifica con el tablero si la nueva posición es válida (límites y muros)
        if (tablero.esMovimientoValido(nuevaFila, nuevaColumna)) {
            this.fila = nuevaFila;
            this.columna = nuevaColumna;
        }
        // si no es válido, se queda quieto ese turno
    }

    public void atacar(Jugador j) {
        if (this.activo && j.estaVivo()) {
            j.recibirDaño(this.daño);
        }
    }

    public boolean verificarColision(Jugador j) {
        return this.activo && (this.fila == j.getFila() && this.columna == j.getColumna());
    }

    public void mostrarEstado() {
        System.out.println("--- Estado del Enemigo ---");
        System.out.println("Tipo: " + tipo);
        System.out.println("Posición: [" + fila + ", " + columna + "]");
        System.out.println("Daño: " + daño);
        System.out.println("Activo: " + (activo ? "Sí" : "No"));
        System.out.println("Comportamiento: Se mueve en dirección aleatoria cada turno.");
        System.out.println("--------------------------");
    }

    public String getTipo() {
        return tipo;
    }
    public int getFila() {
        return fila;
    }
    public void setFila(int fila) {
        this.fila = fila;
    }
    public int getColumna() {
        return columna;
    }
    public void setColumna(int columna) {
        this.columna = columna;
    }
    public int getDaño() {
        return daño;
    }
    public boolean isActivo() {
        return activo;
    }
    public void setActivo(boolean activo) {
        this.activo = activo;
    }
}
