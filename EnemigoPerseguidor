public class EnemigoPerseguidor {
    private String tipo;
    private int fila;
    private int columna;
    private int daño;
    private boolean activo;

    public EnemigoPerseguidor(int fila, int columna, int daño) {
        this.tipo = "perseguidor";
        this.fila = fila;
        this.columna = columna;
        this.daño = daño;
        this.activo = true;
    }

    public void mover(Tablero tablero, Jugador jugador) {
        if (!activo || !jugador.estaVivo()) return;

        int nuevaFila = this.fila;
        int nuevaColumna = this.columna;

        int difFila = jugador.getFila() - this.fila;
        int difColumna = jugador.getColumna() - this.columna;

        if (Math.abs(difFila) >= Math.abs(difColumna) && difFila != 0) {
            // Intentar moverse verticalmente
            nuevaFila += (difFila > 0) ? 1 : -1;
        } else if (difColumna != 0) {
            // Intentar moverse horizontalmente
            nuevaColumna += (difColumna > 0) ? 1 : -1;
        }

        if (tablero.esMovimientoValido(nuevaFila, nuevaColumna)) {
            this.fila = nuevaFila;
            this.columna = nuevaColumna;
        } else {
            // CAMINO ALTERNATIVO
            nuevaFila = this.fila;
            nuevaColumna = this.columna;

            if (Math.abs(difFila) >= Math.abs(difColumna)) {
                // Si falló vertical, intenta horizontal
                if (difColumna != 0) nuevaColumna += (difColumna > 0) ? 1 : -1;
            } else {
                // Si falló horizontal, intenta vertical
                if (difFila != 0) nuevaFila += (difFila > 0) ? 1 : -1;
            }

            if (tablero.esMovimientoValido(nuevaFila, nuevaColumna)) {
                this.fila = nuevaFila;
                this.columna = nuevaColumna;
            }
        }
    }

    public void atacar(Jugador j) {
        if (this.activo && j.estaVivo()) {
            j.recibirDaño(this.daño);
        }
    }

    public boolean verificarColision(Jugador j) {
        return this.activo && (this.fila == j.getFila() && this.columna == j.getColumna());
    }

    public void mostrarEstado() {
        System.out.println("--- Estado del Enemigo ---");
        System.out.println("Tipo: " + this.tipo);
        System.out.println("Posición: [" + this.fila + ", " + this.columna + "]");
        System.out.println("Daño: " + this.daño);
        System.out.println("Activo: " + (this.activo ? "Sí" : "No"));
        System.out.println("Comportamiento: Persigue activamente al jugador en cada turno.");
        System.out.println("--------------------------");
    }

    public String getTipo() { return tipo; }
    public int getFila() { return fila; }
    public void setFila(int fila) { this.fila = fila; }
    public int getColumna() { return columna; }
    public void setColumna(int columna) { this.columna = columna; }
    public int getDaño() { return daño; }
    public boolean isActivo() { return activo; }
    public void setActivo(boolean activo) { this.activo = activo; }
}
