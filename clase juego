
import java.util.Scanner;

public class Juego {
    private Jugador jugador;
    private Tablero tablero;
    private Enemigo[] enemigos;
    private boolean juegoTerminado;
    private ControlEnemigos controlEnemigos;
    private int totalEnemigos;
    private int poderesRecogidos;
    private Scanner lector;

    public Juego() {
        lector = new Scanner(System.in);
        juegoTerminado = false;
        poderesRecogidos = 0;
    }

    // menu
    public static void main(String[] args) {
        Juego juego = new Juego();
        juego.menuPrincipal();
    }

    public void menuPrincipal() {
        int opcion;
        do {
            System.out.println("\n===== PAC-MAN =====");
            System.out.println("1. Iniciar juego");
            System.out.println("2. Salir");
            System.out.print("Elige una opción: ");

            while (!lector.hasNextInt()) {
                System.out.print("Ingresa un número válido: ");
                lector.next();
            }
            opcion = lector.nextInt();

            switch (opcion) {
                case 1:
                    iniciarJuego();
                    jugar();
                    break;
                case 2:
                    System.out.println("Saliendo del juego...");
                    break;
                default:
                    System.out.println("Opción inválida.");
            }
        } while (opcion != 2);
    }

    // inicio
    public void iniciarJuego() {
        System.out.print("Nombre del jugador: ");
        lector.nextLine();
        String nombre = lector.nextLine();

        int filas = pedirEntero("Número de filas: ", 1, Integer.MAX_VALUE);
        int columnas = pedirEntero("Número de columnas: ", 1, Integer.MAX_VALUE);
        int cantidadEnemigos = 3;

        tablero = new Tablero(filas, columnas);

        System.out.println("\n¿Cómo quieres generar los muros internos?");
        System.out.println("1. Automático");
        System.out.println("2. Manual");
        int modoMuros = pedirEntero("Elige una opción: ", 1, 2);

        if (modoMuros == 1) {
            tablero.generarTablero();
        } else {
            int espacioInterior = filas * columnas;
            int cantidadMuros = pedirEntero(
                    "¿Cuántos muros internos quieres? (máximo " + espacioInterior + "): ",
                    0, espacioInterior);
            tablero.generarTablero(cantidadMuros);
        }

        int[] posJugador = tablero.obtenerPosicionLibreAleatoria();
        jugador = new Jugador(nombre, posJugador[0], posJugador[1]);

        generarEnemigos(cantidadEnemigos);
        controlEnemigos = new ControlEnemigos(enemigos, jugador, tablero, totalEnemigos);

        juegoTerminado = false;
        poderesRecogidos = 0;

        System.out.println("\n¡Juego iniciado! Objetivo: recolectar el 50% de todos los puntos sin morir.");
        System.out.println("Controles: w (arriba), s (abajo), a (izquierda), d (derecha), q (salir)\n");
        actualizarTablero();
    }

    public void generarEnemigos(int cantidad) {
        enemigos = new Enemigo[cantidad];
        totalEnemigos = 0;

        for (int i = 0; i < cantidad; i++) {
            int[] pos = tablero.obtenerPosicionLibreAleatoria();
            // evitar sobreposiciones
            while (pos[0] == jugador.getFila() && pos[1] == jugador.getColumna()) {
                pos = tablero.obtenerPosicionLibreAleatoria();
            }

            int tipo = i % 3;
            switch (tipo) {
                case 0:
                    enemigos[i] = new EnemigoPerseguidor(pos[0], pos[1], 1);
                    break;
                case 1:
                    enemigos[i] = new EnemigoAleatorio(pos[0], pos[1]);
                    break;
                case 2:
                    enemigos[i] = new EnemigoFantasma(pos[0], pos[1]);
                    break;
            }
            totalEnemigos++;
        }
    }

    public void jugar() {
        while (!juegoTerminado) {
            ejecutarTurno();
        }
    }

    public void ejecutarTurno() {
        System.out.print("Movimiento (w/a/s/d, q para salir): ");
        String entrada = lector.nextLine().trim().toLowerCase();

        if (entrada.isEmpty()) return;
        char direccion = entrada.charAt(0);

        if (direccion == 'q') {
            juegoTerminado = true;
            System.out.println("Juego terminado por el jugador.");
            return;
        }

        int filaAnterior = jugador.getFila();
        int columnaAnterior = jugador.getColumna();

        jugador.mover(direccion);

        if (!tablero.esMovimientoValido(jugador.getFila(), jugador.getColumna())) {
            jugador.setFila(filaAnterior);
            jugador.setColumna(columnaAnterior);
            System.out.println("Movimiento inválido, hay un muro.");
        } else {
            procesarCelda();
        }

        jugador.actualizarEstadoPoder();
        controlEnemigos.generarMovimientos();
        controlEnemigos.verificarColisiones();
        controlEnemigos.eliminarEnemigosInactivos();

        mostrarEstado();
        actualizarTablero();
        verificarFinJuego();
    }
    private void procesarCelda() {
        char celda = tablero.getMatriz()[jugador.getFila()][jugador.getColumna()];

        if (celda == '.') {
            Punto p = new Punto(jugador.getFila(), jugador.getColumna(), 1);
            jugador.recogerPunto(p);
            tablero.setMatriz(jugador.getFila(), jugador.getColumna(), ' ');
        } else if (celda == 'P') {
            if (poderesRecogidos < tablero.getTotalPoderes()) {
                Poder poder = tablero.getPoderes()[poderesRecogidos];
                jugador.usarPoder(poder);
                poderesRecogidos++;
            }
            tablero.setMatriz(jugador.getFila(), jugador.getColumna(), ' ');
        }
    }

    // info:
    public void actualizarTablero() {
        char[][] matriz = tablero.getMatriz();

        for (int i = 0; i < tablero.getFilas(); i++) {
            for (int j = 0; j < tablero.getColumnas(); j++) {
                char base = matriz[i][j];

                if (i == jugador.getFila() && j == jugador.getColumna()) {
                    System.out.print('@');
                } else {
                    char simbolo = base;
                    for (int k = 0; k < totalEnemigos; k++) {
                        if (enemigos[k] != null && enemigos[k].isActivo()
                                && enemigos[k].getFila() == i && enemigos[k].getColumna() == j) {
                            simbolo = simboloEnemigo(enemigos[k].getTipo());
                        }
                    }
                    System.out.print(simbolo);
                }
            }
            System.out.println();
        }
    }

    private char simboloEnemigo(String tipo) {
        switch (tipo) {
            case "perseguidor": return 'X';
            case "aleatorio": return 'A';
            case "fantasma": return 'F';
            default: return 'E';
        }
    }

    public void mostrarEstado() {
        jugador.mostrarEstado();
        for (int i = 0; i < totalEnemigos; i++) {
            if (enemigos[i] != null) {
                enemigos[i].mostrarEstado();
            }
        }
    }

    public void verificarFinJuego() {
        if (!jugador.estaVivo()) {
            juegoTerminado = true;
            System.out.println("\n" + jugador.getNombre() + " perdió toda su salud. Juego terminado!");
        } else {
            int puntosNecesarios = (int) Math.ceil(tablero.getTotalPuntos() * 0.5);
            if (jugador.getPuntaje() >= puntosNecesarios) {
                juegoTerminado = true;
                System.out.println("\n¡" + jugador.getNombre() + " recolectó el 50% de los puntos, ganaste!");
            }
        }
    }

    private int pedirEntero(String mensaje, int min, int max) {
        int valor;
        do {
            System.out.print(mensaje);
            while (!lector.hasNextInt()) {
                System.out.print("Ingresa un número válido: ");
                lector.next();
            }
            valor = lector.nextInt();
        } while (valor < min || valor > max);
        return valor;
    }
}
